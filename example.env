HOST=0.0.0.0
SERVER_PORT=8080
# App runtime values for local non-Docker runs.
POSTGRES_URL=jdbc:postgresql://localhost:5432/shelf
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
JWT_SECRET=MySuperStrongSecret
JWT_ISSUER=Shelf
JWT_DURATION=30
HARDCOVER_URL=https://api.hardcover.app/v1/graphql
HARDCOVER_API_KEY=<hardcover-api-key>
IMPORT_SCAN_ROOTS=/absolute/path/to/imports
STORAGE_PATH=./storage
VALKEY_URL=redis://localhost:6379
CORS_ALLOWED_HOSTS=localhost:3000,localhost:4173
PUBLIC_ROOT_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080
OBSERVABILITY_ENABLED=true
OBSERVABILITY_ENVIRONMENT=development
OBSERVABILITY_TRACING_ENABLED=true
OBSERVABILITY_TRACE_OWNER=app
OBSERVABILITY_METRICS_ENABLED=true
OBSERVABILITY_PROMETHEUS_ENABLED=true
OBSERVABILITY_OTLP_METRICS_ENABLED=true
OBSERVABILITY_METRICS_PATH=/metrics
OBSERVABILITY_TRACE_SAMPLING_RATIO=1.0
OBSERVABILITY_JSON_LOGS_ENABLED=false
OTEL_SERVICE_NAME=shelf-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_JAVAAGENT_ENABLED=false
# In hybrid mode keep this empty and let backend-entrypoint.sh force Ktor agent instrumentation off.
OTEL_INSTRUMENTATION_KTOR_ENABLED=

# Production/image compose overrides. Use these in `.env` when running `podman compose`
# so host-local values do not accidentally replace container service names.
COMPOSE_IMPORT_SCAN_ROOTS=/storage
COMPOSE_STORAGE_PATH=/storage
COMPOSE_VALKEY_URL=redis://valkey:6379
COMPOSE_BACKEND_URL=http://backend:8080
COMPOSE_CORS_ALLOWED_HOSTS=localhost:3000
COMPOSE_PUBLIC_ROOT_URL=http://localhost:3000
COMPOSE_OTEL_EXPORTER_OTLP_ENDPOINT=http://lgtm:4317

# Dev compose overrides for bind-mounted hot reload.
DEV_COMPOSE_IMPORT_SCAN_ROOTS=/workspace/storage
DEV_COMPOSE_STORAGE_PATH=/workspace/storage
DEV_COMPOSE_VALKEY_URL=redis://valkey:6379
DEV_COMPOSE_BACKEND_URL=http://backend:8080
DEV_COMPOSE_CORS_ALLOWED_HOSTS=localhost:4173
DEV_COMPOSE_PUBLIC_ROOT_URL=http://localhost:4173
DEV_COMPOSE_OTEL_EXPORTER_OTLP_ENDPOINT=http://lgtm:4317

# Override any of the values above to match your deployment environment.
